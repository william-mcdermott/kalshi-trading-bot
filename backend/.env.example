# Kalshi API credentials
# Get these from kalshi.com → Settings → API
KALSHI_API_KEY_ID=your-api-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem
KALSHI_HOST=https://api.elections.kalshi.com/trade-api/v2

# Set to false when ready to place real orders
DRY_RUN=true

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# Default position size in dollars per trade
DEFAULT_POSITION_SIZE=1.0
